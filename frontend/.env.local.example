# Copy to .env.local and fill in.

# Chain (defaults match the deployed Kite testnet contracts)
NEXT_PUBLIC_KITE_RPC_URL=https://rpc-testnet.gokite.ai/
NEXT_PUBLIC_KITE_CHAIN_ID=2368
NEXT_PUBLIC_KITE_EXPLORER_URL=https://testnet.kitescan.ai

# Contract addresses (paste from contracts/deployments/2368.json)
NEXT_PUBLIC_SERVICE_REGISTRY=
NEXT_PUBLIC_AGENT_REGISTRY=
NEXT_PUBLIC_ATTESTATION_LOGGER=
NEXT_PUBLIC_USDC=

# Gateway base URL — used for the `/api/v1/services` directory feed.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# WalletConnect (RainbowKit) project id from https://cloud.reown.com
# Needed for the /register and any write-path; reads work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
