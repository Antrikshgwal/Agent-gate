# =============================================================================
# AgentGate — environment template
# Copy to .env (which is gitignored) and fill in real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Kite Chain (testnet) — values verified against docs.gokite.ai (May 2026).
# -----------------------------------------------------------------------------
KITE_RPC_URL=https://rpc-testnet.gokite.ai/
KITE_CHAIN_ID=2368
KITE_EXPLORER_URL=https://testnet.kitescan.ai/
KITE_FAUCET_URL=https://faucet.gokite.ai

# -----------------------------------------------------------------------------
# x402 facilitator — Pieverse facilitator on Kite testnet.
# Endpoints: POST {url}/v2/verify, POST {url}/v2/settle
# Request header that carries the authorization: X-PAYMENT (uppercase).
# Settlement body includes:  "network": "kite-testnet"
# -----------------------------------------------------------------------------
KITE_FACILITATOR_URL=https://facilitator.pieverse.io
KITE_FACILITATOR_NETWORK=kite-testnet

# -----------------------------------------------------------------------------
# Stablecoin used for payments + reputation stakes.
#
# NOTE: We haven't confirmed an official testnet USDC address on Kite yet.
# Until we do, the deployed MyToken at the address below is the stand-in.
# CAVEAT: MyToken uses 18 decimals; real USDC uses 6. Contracts that assume
# 6 decimals must either be tested against a 6-decimal mock or have the
# decimals override added to MyToken before integration tests are trusted.
# -----------------------------------------------------------------------------
USDC_ADDR=0x735746111a91b5fd6f19fc274505aca0e2c31679

# -----------------------------------------------------------------------------
# Deployed AgentGate contracts (filled in after chunks 2–5 are deployed).
# -----------------------------------------------------------------------------
SERVICE_REGISTRY_ADDR=
AGENT_REGISTRY_ADDR=
ATTESTATION_LOGGER_ADDR=

# -----------------------------------------------------------------------------
# Wallets
#   PRIVATE_KEY            — deploys contracts + owns them
#   GATEWAY_PRIVATE_KEY    — gateway wallet; receives x402 payments, logs
#                            attestations (set as AttestationLogger owner)
# Never reuse a mainnet key. Hex with 0x prefix.
# -----------------------------------------------------------------------------
PRIVATE_KEY=
GATEWAY_WALLET_ADDRESS=
GATEWAY_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Gateway service
# -----------------------------------------------------------------------------
GATEWAY_PORT=3000

# -----------------------------------------------------------------------------
# External APIs proxied through the gateway (one per registered service)
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=

# -----------------------------------------------------------------------------
# Agent identity
#
# NOTE: Kite Agent Passport is installed as a local CLI/daemon via
#   curl -fsSL https://agentpassport.ai/install.sh | bash
# and authenticates via passkey on the user's device — NOT via an API key
# the agent code holds. The SDK design needs to shell out to the local
# binary (kpass) or talk to a local HTTP endpoint. This var is a placeholder
# until that integration is wired up.
# -----------------------------------------------------------------------------
AGENT_DID=

# -----------------------------------------------------------------------------
# Frontend (Next.js needs NEXT_PUBLIC_* — copy to frontend/.env.local)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_KITE_RPC_URL=https://rpc-testnet.gokite.ai/
NEXT_PUBLIC_KITE_CHAIN_ID=2368
NEXT_PUBLIC_SERVICE_REGISTRY_ADDR=
NEXT_PUBLIC_AGENT_REGISTRY_ADDR=
NEXT_PUBLIC_ATTESTATION_LOGGER_ADDR=
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000
